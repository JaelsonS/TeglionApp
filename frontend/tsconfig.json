{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@/app/*": [
        "src/features/*"
      ],
      "@/utils/*": [
        "src/shared/utils/*"
      ],
      "@/lib/*": [
        "src/shared/lib/*"
      ],
      "@/types/*": [
        "src/shared/types/*"
      ],
      "@/constants/*": [
        "src/shared/constants/*"
      ],
      "@/config/*": [
        "src/shared/config/*"
      ],
      "@/components/*": [
        "src/shared/components/*"
      ],
      "@/hooks/*": [
        "src/shared/hooks/*"
      ],
      "@/contexts/*": [
        "src/shared/contexts/*"
      ],
      "@/providers/*": [
        "src/shared/providers/*"
      ],
      "@/design-system/*": [
        "src/shared/design-system/*"
      ],
      "@/styles/*": [
        "src/shared/styles/*"
      ],
      "@/i18n/*": [
        "src/shared/i18n/*"
      ],
      "@/services/*": [
        "src/infrastructure/*"
      ],
      "@/api/*": [
        "src/infrastructure/api/*"
      ],
      "@/App": [
        "src/core/App.tsx"
      ],
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "src",
    "vite.config.ts"
  ]
}