{
  "name": "contabil-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "dev:clean": "rm -rf node_modules/.vite && vite --host 0.0.0.0 --port 3000",
    "start": "vite --host 0.0.0.0 --port 3000",
    "build": "npm run seo:generate && vite build && npm run prerender",
    "build:spa": "npm run seo:generate && vite build",
    "postinstall": "node node_modules/esbuild/install.js",
    "seo:generate": "node scripts/generate-seo-assets.mjs && tsx scripts/generate-blog-catalog.ts",
    "prerender": "tsx scripts/prerender-static.ts",
    "prerender:browser": "node scripts/prerender-public.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "vercel:deploy": "vercel deploy --prod --force --skip-build --no-confirm",
    "vercel:rollback": "vercel rollback --prod",
    "vercel:logs": "vercel logs --prod",
    "vercel:status": "vercel inspect"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.0.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/react": "^9.47.1",
    "@tanstack/react-query": "^5.100.11",
    "autoprefixer": "^10.4.20",
    "axios": "^1.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^11.18.2",
    "i18next": "^25.7.3",
    "lucide-react": "^0.507.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.56.2",
    "react-i18next": "^16.5.1",
    "react-phone-number-input": "^3.4.14",
    "react-router-dom": "^7.5.1",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^3.4.17",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "esbuild": "^0.28.1",
    "globals": "15.15.0",
    "happy-dom": "^20.7.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.6"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.28.1",
    "@rollup/rollup-linux-x64-gnu": "4.62.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "packageManager": "npm@11.8.0"
}