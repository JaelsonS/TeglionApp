{
  "name": "contabil-backend",
  "version": "2.0.0",
  "private": true,
  "description": "TegLion — Backend SaaS para escritórios de contabilidade",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "echo 'Build step complete - Node.js project'",
    "test": "node --test 'src/**/*.test.js'",
    "test:unit": "node --test src/utils/file-magic-bytes.test.js",
    "test:security-static": "node scripts/security-static-audit.js",
    "test:security": "npm run test:security-static && npm run test:tenant-isolation",
    "test:tenant-isolation": "node scripts/tenant-isolation-test.js",
    "runbook:drill": "node scripts/runbook-incident-drill.js",
    "release:gate": "node scripts/release-gate.js",
    "test:portal-hub": "node scripts/portal-hub-smoke-test.js",
    "benchmark:dashboard": "node scripts/benchmark-dashboard.js",
    "storage:validate": "node scripts/validate-storage.js",
    "postinstall": "echo 'Dependencies installed successfully'",
    "smoke:pilot": "node scripts/pilot-smoke-e2e.js"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@sentry/node": "^10.58.0",
    "@supabase/supabase-js": "^2.106.0",
    "argon2": "^0.41.1",
    "axios": "^1.18.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.19",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "rate-limit-redis": "^4.2.0",
    "stripe": "^16.12.0",
    "web-push": "^3.6.7",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "overrides": {
    "@fast-csv/format": "^5.0.5",
    "fast-csv": "^5.0.5",
    "formidable": "^3.5.4",
    "glob": "^9.3.5",
    "rimraf": "^5.0.5",
    "superagent": "^10.2.3",
    "unzipper": "^0.12.3"
  }
